{
  "name": "claude-board",
  "version": "3.2.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server.js",
    "setup": "npm install && cd client && npm install",
    "lint": "eslint src/ server.js && cd client && npx eslint src/",
    "lint:fix": "eslint src/ server.js --fix && cd client && npx eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"server.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"server.js\"",
    "prepare": "husky"
  },
  "dependencies": {
    "concurrently": "^9.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "socket.io": "^4.8.0",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "gif-encoder-2": "^1.0.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.1",
    "puppeteer": "^24.39.1"
  },
  "lint-staged": {
    "src/**/*.js": [
      "eslint --max-warnings 5",
      "prettier --check"
    ],
    "server.js": [
      "eslint --max-warnings 5",
      "prettier --check"
    ],
    "client/src/**/*.{js,jsx}": [
      "eslint --max-warnings 10"
    ]
  }
}
