{
  "name": "claude-board",
  "version": "1.8.1",
  "private": true,
  "description": "Visual task management board for Claude Code — manage AI-powered development tasks with a Kanban-style interface",
  "author": {
    "name": "Bahri Hirfanoglu",
    "email": "bahri@hirfanoglu.com"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "scripts": {
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "setup": "npm install && cd client && npm install",
    "tauri": "tauri",
    "tauri:dev": "npx tauri dev",
    "tauri:build": "npx tauri build",
    "lint": "cd client && npx eslint src/",
    "lint:fix": "cd client && npx eslint src/ --fix",
    "format": "prettier --write \"client/src/**/*.{js,jsx}\"",
    "test": "cd client && npx vitest run",
    "format:check": "prettier --check \"client/src/**/*.{js,jsx}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2"
  },
  "lint-staged": {
    "client/src/**/*.{js,jsx}": [
      "eslint --max-warnings 10"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  }
}
