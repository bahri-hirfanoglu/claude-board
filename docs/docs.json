{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Claude Board",
  "description": "Build your own AI dev squad. Run multiple agents from your local machine.",
  "colors": {
    "primary": "#DA7756",
    "light": "#E8926E",
    "dark": "#C45A3C"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://github.com/bahri-hirfanoglu/claude-board"
  },
  "favicon": "/favicon.png",
  "appearance": {
    "default": "dark"
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/bahri-hirfanoglu/claude-board"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Download",
      "href": "https://github.com/bahri-hirfanoglu/claude-board/releases/latest"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "rocket",
            "pages": ["introduction", "installation", "quickstart"]
          },
          {
            "group": "Core Concepts",
            "icon": "lightbulb",
            "pages": ["concepts/board", "concepts/tasks", "concepts/agents", "concepts/review"]
          },
          {
            "group": "Orchestration",
            "icon": "sitemap",
            "pages": [
              "features/orchestration",
              "features/dependencies",
              "features/queue",
              "features/planning-mode",
              "features/retry-backoff",
              "features/failed-status",
              "features/task-timeout"
            ]
          },
          {
            "group": "Execution & Testing",
            "icon": "play",
            "pages": [
              "features/terminal",
              "features/split-terminal",
              "features/session-replay",
              "features/auto-test",
              "features/diff-viewer"
            ]
          },
          {
            "group": "Git & Deployment",
            "icon": "code-branch",
            "pages": [
              "features/git-automation",
              "features/auto-pr",
              "features/webhooks"
            ]
          },
          {
            "group": "AI Configuration",
            "icon": "wand-magic-sparkles",
            "pages": [
              "features/roles",
              "features/custom-commands",
              "features/skill-import",
              "features/scan",
              "features/claude-manager"
            ]
          },
          {
            "group": "Content & Templates",
            "icon": "file-lines",
            "pages": [
              "features/templates",
              "features/prompt-templates",
              "features/snippets",
              "features/attachments"
            ]
          },
          {
            "group": "Analytics & UI",
            "icon": "chart-bar",
            "pages": [
              "features/analytics",
              "features/token-counter",
              "features/task-keys",
              "features/model-filter",
              "features/status-animations",
              "features/voice-assistant"
            ]
          },
          {
            "group": "Configuration",
            "icon": "gear",
            "pages": [
              "configuration/projects",
              "configuration/permissions",
              "configuration/claude-md",
              "configuration/environment"
            ]
          },
          {
            "group": "Desktop App",
            "icon": "desktop",
            "pages": [
              "desktop/setup",
              "desktop/builds",
              "features/settings",
              "features/notifications"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Endpoints",
            "icon": "code",
            "pages": [
              "api/projects",
              "api/tasks",
              "api/planning",
              "api/webhooks",
              "api/snippets",
              "api/templates",
              "api/stats"
            ]
          },
          {
            "group": "Real-time",
            "icon": "bolt",
            "pages": ["api/events"]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/bahri-hirfanoglu/claude-board"
    }
  }
}
